@page "/news/{Slug}"
@inject INewsService NewsService
@inject NavigationManager Nav
@using HDA.Domain.Entities
@using HDA.Infrastructure.Services
@using MudBlazor

<PageTitle>@(_article?.Title ?? "News") — HDA.gg</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_article == null)
{
    <MudAlert Severity="Severity.Error">Article not found.</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <!-- Back -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-4">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/news"))" Size="Size.Small" />
                <MudText Typo="Typo.caption" Style="color:#8A8AAA;">Back to News</MudText>
            </MudStack>

            <!-- Header -->
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="mb-3">@_article.Category</MudChip>

            <MudText Typo="Typo.h3" Style="color:#EAEAEA; font-weight:900; line-height:1.2;" Class="mb-3">
                @_article.Title
            </MudText>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudAvatar Size="Size.Small" Color="Color.Primary" Style="font-weight:700; font-size:0.75rem;">
                    @_article.Author?.Username[0].ToString().ToUpper()
                </MudAvatar>
                <MudText Typo="Typo.body2" Style="color:#8A8AAA;">
                    @_article.Author?.Username
                </MudText>
                <MudText Typo="Typo.body2" Style="color:#1E1E3A;">•</MudText>
                <MudText Typo="Typo.body2" Style="color:#8A8AAA;">
                    @_article.PublishedAt?.ToString("MMMM dd, yyyy")
                </MudText>
            </MudStack>

            @if (_article.ImageUrl != null)
            {
                <MudPaper Elevation="0" Style="border-radius:12px; overflow:hidden; margin-bottom:24px;">
                    <img src="@_article.ImageUrl" alt="@_article.Title"
                         style="width:100%; max-height:400px; object-fit:cover; display:block;" />
                </MudPaper>
            }

            <!-- Content -->
            <MudPaper Elevation="0" Style="background:#16213E; border:1px solid #1E1E3A; border-radius:12px; padding:32px;">
                @if (_article.Summary != null)
                {
                    <MudText Typo="Typo.body1" Style="color:#EAEAEA; font-weight:500; font-size:1.1rem; line-height:1.7; border-left:3px solid #E84057; padding-left:16px; margin-bottom:24px;">
                        @_article.Summary
                    </MudText>
                }
                <MudText Typo="Typo.body1" Style="color:#EAEAEA; line-height:1.8; white-space:pre-wrap;">
                    @_article.Content
                </MudText>
            </MudPaper>

            <!-- Share -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-4">
                <MudText Typo="Typo.body2" Style="color:#8A8AAA;">Share:</MudText>
                <MudChip T="string" Size="Size.Small" Style="background:#1DA1F2; color:white; cursor:pointer;">Twitter / X</MudChip>
                <MudChip T="string" Size="Size.Small" Style="background:#0A66C2; color:white; cursor:pointer;">LinkedIn</MudChip>
            </MudStack>
        </MudItem>

        <!-- Sidebar: More News -->
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.h6" Class="mb-3" Style="color:#EAEAEA;">More News</MudText>
            @foreach (var n in _moreNews.Where(n => n.Slug != Slug))
            {
                <MudPaper Elevation="0" Style="background:#16213E; border:1px solid #1E1E3A; border-radius:8px; padding:12px; margin-bottom:8px; cursor:pointer;"
                          onclick="@(() => Nav.NavigateTo($"/news/{n.Slug}"))">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Style="font-size:0.6rem; margin-bottom:4px;">@n.Category</MudChip>
                    <MudText Typo="Typo.body2" Style="color:#EAEAEA; font-weight:500; line-height:1.3;">@n.Title</MudText>
                    <MudText Typo="Typo.caption" Style="color:#8A8AAA; display:block; margin-top:4px;">
                        @n.PublishedAt?.ToString("MMM dd, yyyy")
                    </MudText>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private NewsArticle? _article;
    private List<NewsArticle> _moreNews = [];
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _article = await NewsService.GetBySlugAsync(Slug);
        _moreNews = await NewsService.GetPublishedAsync(pageSize: 6);
        _loading = false;
    }
}
