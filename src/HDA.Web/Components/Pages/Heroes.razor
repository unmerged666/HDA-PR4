@page "/heroes"
@inject IOpenDotaService OpenDotaService
@inject AppState AppState
@using HDA.Domain.Entities
@using HDA.Infrastructure.Services
@using MudBlazor

<PageTitle>Герои Dota 2 — HDA.gg</PageTitle>

<div style="display:flex;align-items:flex-start;justify-content:space-between;padding:20px 28px 16px;border-bottom:1px solid var(--border);">
    <div>
        <div class="page-title">Герои Dota 2</div>
        <div class="page-sub">@_filtered.Count() @(_filtered.Count()==1?"герой":"героев") · нажмите для деталей</div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
        @if (AppState.IsAdmin)
        {
            <button class="btn-sm" @onclick="Sync" disabled="@_syncing">@(_syncing?"Синхронизация...":"↻ Синхронизировать")</button>
        }
        <div style="display:flex;align-items:center;background:var(--bg3);border:1px solid var(--border2);border-radius:6px;padding:0 10px;width:180px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--t3)" stroke-width="2" style="flex-shrink:0;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input @bind="_search" @bind:event="oninput" placeholder="Найти героя..."
                   style="background:transparent;border:none;outline:none;padding:6px 8px;font-size:12px;color:var(--t1);font-family:var(--font-body);width:100%;" />
        </div>
    </div>
</div>

<!-- Filters -->
<div style="padding:10px 28px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
    <div style="display:flex;gap:4px;align-items:center;">
        <span style="font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--t4);margin-right:4px;font-family:var(--font-display);">АТРИБУТ</span>
        @foreach (var (val, lbl, clr) in new[]{("","Все","var(--t2)"),("str","Сила","#E8724A"),("agi","Ловкость","#4ADE80"),("int","Интеллект","#60A5FA"),("all","Универсал","#C084FC")})
        {
            var isActive = _attrF == val;
            <button @onclick="@(()=>{ _attrF=val; _sel=0; })"
                    style="@($"padding:4px 10px;border-radius:5px;font-size:9px;font-weight:700;letter-spacing:1px;font-family:var(--font-display);text-transform:uppercase;border:1px solid {(isActive?"var(--accent)":"var(--border2)")};background:{(isActive?"var(--accent-a)":"transparent")};color:{(isActive?clr:isActive?"var(--t2)":clr)};cursor:pointer;transition:all .2s;")">
                @if (val!="") { <span style="width:6px;height:6px;border-radius:50%;background:@clr;display:inline-block;margin-right:4px;"></span> }
                @lbl
            </button>
        }
    </div>
    <div style="width:1px;height:16px;background:var(--border2);margin:0 4px;"></div>
    <div style="display:flex;gap:4px;align-items:center;">
        <span style="font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--t4);margin-right:4px;font-family:var(--font-display);">АТАКА</span>
        @foreach (var (val, lbl) in new[]{("","Все"),("Melee","Ближний"),("Ranged","Дальний")})
        {
            var isActive = _atkF == val;
            <button @onclick="@(()=>{ _atkF=val; _sel=0; })"
                    style="@($"padding:4px 10px;border-radius:5px;font-size:9px;font-weight:700;letter-spacing:1px;font-family:var(--font-display);text-transform:uppercase;border:1px solid {(isActive?"var(--accent)":"var(--border2)")};background:{(isActive?"var(--accent-a)":"transparent")};color:{(isActive?"var(--accent)":"var(--t3)")};cursor:pointer;transition:all .2s;")">
                @lbl
            </button>
        }
    </div>
    @if (!string.IsNullOrEmpty(_attrF) || !string.IsNullOrEmpty(_atkF) || !string.IsNullOrEmpty(_search))
    {
        <button @onclick="@(()=>{ _attrF=""; _atkF=""; _search=""; _sel=0; })"
                style="padding:4px 10px;border-radius:5px;font-size:9px;font-weight:700;font-family:var(--font-display);letter-spacing:1px;text-transform:uppercase;border:1px solid var(--border2);background:transparent;color:var(--accent);cursor:pointer;transition:all .2s;margin-left:4px;">
            ✕ Сбросить
        </button>
    }
    <span style="margin-left:auto;font-size:10px;color:var(--t4);font-family:var(--font-mono);">@_filtered.Count() @GetHeroWord(_filtered.Count())</span>
</div>

@if (_loading)
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:1px;background:var(--border);padding:0;">
        @for (int i = 0; i < 24; i++)
        { <div style="background:var(--bg2);"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="88px" /><div style="padding:6px 8px;"><MudSkeleton Height="10px" Width="70%" /><div style="margin-top:3px;"><MudSkeleton Height="8px" Width="50%" /></div></div></div> }
    </div>
}
else if (!_filtered.Any())
{
    <div style="padding:60px;text-align:center;color:var(--t3);">
        <div style="font-size:48px;margin-bottom:16px;opacity:.3;">⚔</div>
        <div style="font-size:16px;font-weight:700;color:var(--t2);">Герои не найдены</div>
        <div style="font-size:13px;margin-top:8px;color:var(--t4);">Попробуйте изменить фильтры</div>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:1px;background:var(--border);">
        @foreach (var h in _filtered)
        {
            var hClass = _sel == h.Id ? "hero-card selected" : "hero-card";
            <div class="@hClass" @onclick="@(()=>_sel=_sel==h.Id?0:h.Id)">
                <div style="position:relative;height:88px;overflow:hidden;">
                    @if (!string.IsNullOrEmpty(h.ImageUrl))
                    {
                        <img src="@h.ImageUrl" alt="@h.LocalizedName" class="hero-img"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                        <div class="hero-img-placeholder" style="display:none;position:absolute;inset:0;">⚔</div>
                    }
                    else { <div class="hero-img-placeholder">⚔</div> }
                    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(6,10,18,.85) 0%,transparent 55%);pointer-events:none;"></div>
                    <div style="position:absolute;top:4px;right:4px;width:8px;height:8px;border-radius:50%;background:@AC(h.PrimaryAttribute);box-shadow:0 0 6px @AC(h.PrimaryAttribute);"></div>
                    <div style="position:absolute;bottom:5px;left:6px;right:6px;">
                        <div class="hero-name-label">@h.LocalizedName</div>
                    </div>
                </div>
                <div class="hero-info">
                    <div class="hero-roles">@(h.Roles?.Any()==true ? string.Join(" · ", h.Roles.Take(2).Select(RL)) : "—")</div>
                </div>
            </div>
        }
    </div>

    <!-- Selected hero detail bar -->
    @if (_sel > 0)
    {
        var selHero = _heroes.FirstOrDefault(h => h.Id == _sel);
        @if (selHero != null)
        {
            <div style="padding:16px 24px;background:var(--bg2);border-top:2px solid var(--accent);display:flex;align-items:center;gap:16px;flex-wrap:wrap;animation:fadeUp .2s ease;" class="hda-fadein">
                <div style="width:52px;height:52px;border-radius:8px;overflow:hidden;border:2px solid var(--accent);flex-shrink:0;position:relative;">
                    @if (!string.IsNullOrEmpty(selHero.ImageUrl))
                    { <img src="@selHero.ImageUrl" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" /> }
                    else { <div style="width:100%;height:100%;background:var(--bg3);display:flex;align-items:center;justify-content:center;color:var(--accent);font-size:20px;">⚔</div> }
                </div>
                <div>
                    <div style="font-size:20px;font-weight:800;color:var(--t1);font-family:var(--font-display);">@selHero.LocalizedName</div>
                    <div style="display:flex;gap:6px;margin-top:6px;flex-wrap:wrap;align-items:center;">
                        <span style="font-size:10px;font-weight:700;padding:3px 9px;border-radius:5px;background:@(AC(selHero.PrimaryAttribute)+"22");color:@AC(selHero.PrimaryAttribute);border:1px solid @(AC(selHero.PrimaryAttribute)+"44");font-family:var(--font-display);letter-spacing:1px;text-transform:uppercase;">@AL(selHero.PrimaryAttribute)</span>
                        @if (selHero.AttackType != null)
                        { <span style="font-size:10px;font-weight:700;padding:3px 9px;border-radius:5px;background:var(--bg3);color:var(--t2);border:1px solid var(--border);font-family:var(--font-display);letter-spacing:1px;text-transform:uppercase;">@(selHero.AttackType=="Melee"?"Ближний бой":"Дальний бой")</span> }
                        @if (selHero.Roles?.Any()==true)
                        {
                            @foreach (var r in selHero.Roles.Take(6))
                            {
                                <span style="font-size:10px;font-weight:700;padding:3px 9px;border-radius:5px;background:rgba(75,158,255,.1);color:var(--blue);border:1px solid rgba(75,158,255,.2);font-family:var(--font-display);letter-spacing:1px;text-transform:uppercase;margin-right:2px;">@RL(r)</span>
                            }
                        }
                    </div>
                </div>
                <button @onclick="@(()=>_sel=0)" style="margin-left:auto;background:none;border:none;color:var(--t3);cursor:pointer;font-size:20px;line-height:1;transition:color .2s;padding:4px;" title="Закрыть">✕</button>
            </div>
        }
    }
}

@code {
    private List<Hero> _heroes = [];
    private int _sel;
    private string _attrF = "", _atkF = "", _search = "";
    private bool _loading = true, _syncing;

    private IEnumerable<Hero> _filtered => _heroes.Where(h =>
        (string.IsNullOrEmpty(_attrF) || 
            string.Equals(h.PrimaryAttribute, _attrF, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_atkF)  || 
            string.Equals(h.AttackType, _atkF, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_search) || 
            h.LocalizedName.Contains(_search, StringComparison.OrdinalIgnoreCase))
    ).OrderBy(h => h.LocalizedName);

    protected override async Task OnInitializedAsync()
    {
        _heroes = await OpenDotaService.GetHeroesAsync();
        _loading = false;
        if (!_heroes.Any())
        {
            _loading = true;
            try { await OpenDotaService.SyncHeroesAsync(); _heroes = await OpenDotaService.GetHeroesAsync(); }
            catch { }
            _loading = false;
        }
    }

    private async Task Sync()
    {
        _syncing = true;
        try { await OpenDotaService.SyncHeroesAsync(); _heroes = await OpenDotaService.GetHeroesAsync(); }
        catch { }
        _syncing = false;
    }

    private string AC(string? a) => a switch { "str"=>"#E8724A","agi"=>"#4ADE80","int"=>"#60A5FA",_=>"#C084FC" };
    private string AL(string? a) => a switch { "str"=>"Сила","agi"=>"Ловкость","int"=>"Интеллект",_=>"Универсал" };
    private string RL(string r) => r switch
    {
        "Carry"=>"Керри","Support"=>"Саппорт","Nuker"=>"Нюкер","Disabler"=>"Контроль",
        "Initiator"=>"Инициатор","Jungler"=>"Джанглер","Durable"=>"Живучий",
        "Escape"=>"Побег","Pusher"=>"Пушер",_=>r
    };
    private string GetHeroWord(int n)
    {
        var m10 = n % 10; var m100 = n % 100;
        if (m100 >= 11 && m100 <= 14) return "героев";
        return m10 == 1 ? "герой" : (m10 >= 2 && m10 <= 4) ? "героя" : "героев";
    }
}
