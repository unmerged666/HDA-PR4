@page "/teams/compare"
@inject ITeamService TeamService
@inject IMatchService MatchService
@using HDA.Domain.Entities
@using HDA.Domain.Enums
@using HDA.Infrastructure.Services
@using MudBlazor

<PageTitle>Сравнение команд — HDA.gg</PageTitle>

<div style="padding:20px 24px 14px;border-bottom:1px solid var(--border);">
    <div style="font-size:22px;font-weight:900;color:var(--t1);">Сравнение команд</div>
    <div style="font-size:12px;color:var(--t3);margin-top:3px;">Статистика лицом к лицу</div>
</div>

<!-- Team pickers -->
<div style="padding:20px 24px;border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:20px;max-width:800px;">
    <MudSelect T="int" Value="_aId" Label="Команда A" Variant="Variant.Outlined" Dense="true"
               MaxHeight="280" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter"
               ValueChanged="@(async (int v) => { _aId = v; await Load(); })">
        @foreach (var t in _all) { <MudSelectItem Value="t.Id">@t.Name</MudSelectItem> }
    </MudSelect>
    <div style="font-size:14px;font-weight:900;color:var(--t3);">VS</div>
    <MudSelect T="int" Value="_bId" Label="Команда B" Variant="Variant.Outlined" Dense="true"
               MaxHeight="280" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter"
               ValueChanged="@(async (int v) => { _bId = v; await Load(); })">
        @foreach (var t in _all.Where(t => t.Id != _aId)) { <MudSelectItem Value="t.Id">@t.Name</MudSelectItem> }
    </MudSelect>
</div>

@if (_ta == null || _tb == null)
{
    <div style="padding:48px;text-align:center;color:var(--t3);">Выберите две команды для сравнения</div>
}
else
{
    <!-- Team headers -->
    <div style="display:grid;grid-template-columns:1fr 120px 1fr;align-items:center;padding:24px;gap:16px;border-bottom:1px solid var(--border);">
        <div style="text-align:center;">
            <div style="width:64px;height:64px;border-radius:12px;background:var(--bg3);border:1px solid var(--border2);overflow:hidden;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:var(--red);">
                @if (!string.IsNullOrEmpty(_ta.LogoUrl)) { <img src="@_ta.LogoUrl" style="width:100%;height:100%;object-fit:contain;" /> }
                else { @(_ta.Tag.Substring(0,2)) }
            </div>
            <a href="/teams/@_ta.Id" style="font-size:18px;font-weight:900;color:var(--t1);text-decoration:none;">@_ta.Name</a>
            <div style="font-size:11px;color:var(--t3);margin-top:3px;">@_ta.Region · #@_ta.WorldRank</div>
        </div>
        <div style="text-align:center;font-size:13px;font-weight:700;color:var(--t4);">СРАВНЕНИЕ</div>
        <div style="text-align:center;">
            <div style="width:64px;height:64px;border-radius:12px;background:var(--bg3);border:1px solid var(--border2);overflow:hidden;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:var(--red);">
                @if (!string.IsNullOrEmpty(_tb.LogoUrl)) { <img src="@_tb.LogoUrl" style="width:100%;height:100%;object-fit:contain;" /> }
                else { @(_tb.Tag.Substring(0,2)) }
            </div>
            <a href="/teams/@_tb.Id" style="font-size:18px;font-weight:900;color:var(--t1);text-decoration:none;">@_tb.Name</a>
            <div style="font-size:11px;color:var(--t3);margin-top:3px;">@_tb.Region · #@_tb.WorldRank</div>
        </div>
    </div>

    <!-- H2H matches -->
    @if (_h2h.Any())
    {
        <div class="sec" style="margin-top:8px;">
            <div class="sec-title">Личные встречи (@_h2h.Count матчей)</div>
            <div style="font-size:12px;color:var(--t2);">
                <span style="color:var(--green);font-weight:700;">@_aWins</span> — <span style="color:var(--red);font-weight:700;">@_bWins</span>
            </div>
        </div>
        @foreach (var m in _h2h) { <MatchCard Match="m" /> }
    }
    else
    {
        <div style="padding:24px;text-align:center;color:var(--t3);font-size:13px;border-bottom:1px solid var(--border);">Личных встреч не найдено</div>
    }

    <!-- Stats comparison -->
    <div class="sec" style="margin-top:8px;"><div class="sec-title">Общая статистика</div></div>
    @foreach (var (label, aVal, bVal, higherIsBetter) in _stats)
    {
        double aNum = 0, bNum = 0;
        double.TryParse(aVal.TrimStart('#'), out aNum);
        double.TryParse(bVal.TrimStart('#'), out bNum);
        var aBetter = higherIsBetter ? aNum >= bNum : aNum <= bNum;
        var bBetter = higherIsBetter ? bNum >= aNum : bNum <= aNum;
        <div style="display:grid;grid-template-columns:1fr 140px 1fr;align-items:center;padding:12px 24px;border-bottom:1px solid var(--border);gap:12px;">
            <div style="text-align:right;font-size:16px;font-weight:800;color:@(aBetter&&aVal!=bVal?"var(--green)":"var(--t2)");">@aVal</div>
            <div style="text-align:center;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--t4);">@label</div>
            <div style="text-align:left;font-size:16px;font-weight:800;color:@(bBetter&&aVal!=bVal?"var(--green)":"var(--t2)");">@bVal</div>
        </div>
    }

    <!-- Roster comparison -->
    <div class="sec" style="margin-top:8px;"><div class="sec-title">Составы</div></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);">
        @foreach (var (team, side) in new[]{ (_ta, "A"), (_tb, "B") })
        {
            <div style="background:var(--bg2);">
                <div style="padding:10px 16px;font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--t4);border-bottom:1px solid var(--border);">@team.Name</div>
                @foreach (var p in team.Players.OrderBy(x => (int)x.Role))
                {
                    <div style="display:flex;align-items:center;gap:8px;padding:9px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s;"
                         @onclick="@(() => Nav.NavigateTo($"/players/{p.Id}"))">
                        <div style="width:28px;height:28px;border-radius:5px;background:var(--bg3);border:1px solid var(--border);overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--red);">
                            @if (!string.IsNullOrEmpty(p.AvatarUrl)) { <img src="@p.AvatarUrl" style="width:100%;height:100%;object-fit:cover;" /> }
                            else { @p.Nickname[0] }
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:12px;font-weight:700;color:var(--t1);">@p.Nickname</div>
                            <div style="font-size:10px;color:var(--t3);">@RL(p.Role)</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name="a")] public int AId { get; set; }
    [SupplyParameterFromQuery(Name="b")] public int BId { get; set; }
    [Inject] NavigationManager Nav { get; set; } = null!;

    private List<Team> _all = [];
    private Team? _ta, _tb;
    private List<Match> _h2h = [];
    private int _aId, _bId, _aWins, _bWins;

    private List<(string Label, string AVal, string BVal, bool HigherIsBetter)> _stats = [];

    protected override async Task OnInitializedAsync()
    {
        _all = await TeamService.GetRankingsAsync();
        _aId = AId > 0 ? AId : (_all.Count > 0 ? _all[0].Id : 0);
        _bId = BId > 0 ? BId : (_all.Count > 1 ? _all[1].Id : 0);
        await Load();
    }

    private async Task Load()
    {
        if (_aId == 0 || _bId == 0 || _aId == _bId) { _ta = _tb = null; return; }

        _ta = await TeamService.GetDetailAsync(_aId);
        _tb = await TeamService.GetDetailAsync(_bId);
        if (_ta == null || _tb == null) return;

        // H2H
        var aMatches = await TeamService.GetRecentMatchesAsync(_aId, 50);
        _h2h = aMatches.Where(m =>
            (m.TeamAId == _aId && m.TeamBId == _bId) ||
            (m.TeamAId == _bId && m.TeamBId == _aId)).ToList();

        _aWins = _h2h.Count(m => m.WinnerId == _aId);
        _bWins = _h2h.Count(m => m.WinnerId == _bId);

        // Stats
        _stats =
        [
            ("Рейтинг", _ta.RatingPoints.ToString(), _tb.RatingPoints.ToString(), true),
            ("Мировой ранг", $"#{_ta.WorldRank}", $"#{_tb.WorldRank}", false),
            ("Игроков в составе", _ta.Players.Count.ToString(), _tb.Players.Count.ToString(), true),
            ("Побед в личных встречах", _aWins.ToString(), _bWins.ToString(), true),
        ];

        StateHasChanged();
    }

    private string RL(HDA.Domain.Enums.PlayerRole r) => r switch
    { HDA.Domain.Enums.PlayerRole.Carry=>"Керри", HDA.Domain.Enums.PlayerRole.Midlaner=>"Мид", HDA.Domain.Enums.PlayerRole.Offlaner=>"Офф", HDA.Domain.Enums.PlayerRole.SoftSupport=>"4 поз.", HDA.Domain.Enums.PlayerRole.HardSupport=>"Саппорт", _=>r.ToString() };
}
