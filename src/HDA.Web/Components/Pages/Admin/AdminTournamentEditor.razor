@page "/admin/tournaments/{Id:int?}"
@inject ITournamentService TournamentService
@inject ITeamService TeamService
@inject IFileUploadService FileUpload
@inject AppState AppState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IAuthService AuthService
@using HDA.Domain.Entities
@using HDA.Domain.Enums
@using HDA.Infrastructure.Services
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor

<PageTitle>@(_isNew ? "Create Tournament" : "Edit Tournament") — HDA Admin</PageTitle>
@if (!AppState.IsAdmin) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/admin" />
    <MudText Typo="Typo.h5" Style="color:#EAEAEA;">@(_isNew ? "Create Tournament" : "Edit Tournament")</MudText>
</MudStack>

@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" /> }
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Elevation="0" Style="background:#16213E; border:1px solid #1E1E3A; border-radius:12px; padding:24px;">
                <MudText Typo="Typo.h6" Class="mb-4" Style="color:#EAEAEA;">Tournament Details</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_form.Name" Label="Tournament Name *" Variant="Variant.Outlined"
                                      Required="true" FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_form.Organizer" Label="Organizer" Variant="Variant.Outlined"
                                      HelperText="e.g. Valve, ESL, WePlay" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_form.Region" Label="Region" Variant="Variant.Outlined"
                                      HelperText="e.g. Global, Europe, CIS, SEA" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_form.Location" Label="Location" Variant="Variant.Outlined"
                                      HelperText="e.g. Copenhagen, Denmark or Online" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect @bind-Value="_form.Tier" Label="Tier *" Variant="Variant.Outlined">
                            <MudSelectItem Value="TournamentTier.S">S — The International</MudSelectItem>
                            <MudSelectItem Value="TournamentTier.A">A — Major</MudSelectItem>
                            <MudSelectItem Value="TournamentTier.B">B — Minor</MudSelectItem>
                            <MudSelectItem Value="TournamentTier.C">C — Regional League</MudSelectItem>
                            <MudSelectItem Value="TournamentTier.D">D — Open Qualifier</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_form.PrizePool" Label="Prize Pool (USD)" Variant="Variant.Outlined"
                                         Min="0" Format="N0" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect @bind-Value="_form.Status" Label="Status" Variant="Variant.Outlined">
                            @foreach (var s in Enum.GetValues<TournamentStatus>())
                            {
                                <MudSelectItem Value="s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_form.StartDate" Label="Start Date *" Variant="Variant.Outlined"
                                       DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_form.EndDate" Label="End Date *" Variant="Variant.Outlined"
                                       DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_form.Description" Label="Description" Variant="Variant.Outlined"
                                      Lines="3" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_form.LiquipediaUrl" Label="Liquipedia URL" Variant="Variant.Outlined"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Link" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Participants Manager -->
            @if (!_isNew && _tournament != null)
            {
                <MudPaper Elevation="0" Style="background:#16213E; border:1px solid #1E1E3A; border-radius:12px; padding:24px; margin-top:16px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                        <MudText Typo="Typo.h6" Style="color:#EAEAEA;">Participants</MudText>
                        <MudText Typo="Typo.body2" Style="color:#8A8AAA;">@_tournament.Participants.Count teams</MudText>
                    </MudStack>

                    <!-- Add team -->
                    <MudStack Row="true" Spacing="2" Class="mb-3">
                        <MudSelect @bind-Value="_addTeamId" Label="Add Team" Variant="Variant.Outlined"
                                   Margin="Margin.Dense" Style="flex:1;">
                            @foreach (var t in _availableTeams)
                            {
                                <MudSelectItem Value="t.Id">@t.Name (@t.Tag)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddParticipant"
                                   Disabled="_addTeamId == 0">Add</MudButton>
                    </MudStack>

                    @foreach (var p in _tournament.Participants.OrderBy(x => x.FinalPlacement ?? 999))
                    {
                        <MudPaper Elevation="0" Style="background:#0D0D1A; border:1px solid #1E1E3A; border-radius:6px; padding:10px; margin-bottom:6px;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Style="color:#EAEAEA; font-weight:600;">@p.Team?.Name</MudText>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudNumericField @bind-Value="p.FinalPlacement" Label="Place" Variant="Variant.Outlined"
                                                     Margin="Margin.Dense" Style="width:80px;" Min="1" />
                                    <MudNumericField T="decimal?" @bind-Value="p.PrizeWon" Label="Prize $" Variant="Variant.Outlined"
                                                     Margin="Margin.Dense" Style="width:120px;" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }

                    @if (_tournament.Participants.Any())
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SaveParticipants"
                                   Class="mt-2" Size="Size.Small">Save Participant Data</MudButton>
                    }
                </MudPaper>
            }
        </MudItem>

        <!-- Sidebar -->
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Style="background:#16213E; border:1px solid #1E1E3A; border-radius:12px; padding:24px;">
                <MudText Typo="Typo.h6" Class="mb-3" Style="color:#EAEAEA;">Logo</MudText>

                @if (!string.IsNullOrEmpty(_logoPreview))
                {
                    <img src="@_logoPreview" alt="Logo"
                         style="width:100%; height:120px; object-fit:contain; border-radius:8px; background:#0D0D1A; margin-bottom:8px;" />
                }

                <InputFile id="tLogoInput" OnChange="OnLogoSelected" accept="image/*" style="display:none;" />
                <MudButton HtmlTag="label" for="tLogoInput" Variant="Variant.Outlined" Color="Color.Primary"
                           FullWidth="true" Size="Size.Small" Class="mb-4">Upload Logo</MudButton>

                <MudDivider Class="mb-3" />

                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
                               Disabled="_saving" FullWidth="true" StartIcon="@Icons.Material.Filled.Save">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> }
                        else { <span>@(_isNew ? "Create Tournament" : "Save Changes")</span> }
                    </MudButton>
                    @if (!_isNew)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Delete" FullWidth="true">
                            Delete Tournament
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool _isNew => Id == null || Id == 0;
    private Tournament? _tournament;
    private TournamentForm _form = new();
    private List<Team> _allTeams = [];
    private List<Team> _availableTeams = [];
    private int _addTeamId;
    private IBrowserFile? _logoFile;
    private string? _logoPreview;
    private bool _loading = true, _saving;

    protected override async Task OnInitializedAsync()
    {
        _allTeams = await TeamService.GetRankingsAsync();
        if (!_isNew)
        {
            _tournament = await TournamentService.GetDetailAsync(Id!.Value);
            if (_tournament != null)
            {
                _form = new TournamentForm
                {
                    Name = _tournament.Name, Organizer = _tournament.Organizer,
                    Region = _tournament.Region, Location = _tournament.Location,
                    Tier = _tournament.Tier, Status = _tournament.Status,
                    PrizePool = (double)_tournament.PrizePool,
                    StartDate = _tournament.StartDate, EndDate = _tournament.EndDate,
                    Description = _tournament.Description, LiquipediaUrl = _tournament.LiquipediaUrl,
                };
                _logoPreview = _tournament.LogoUrl;
                UpdateAvailableTeams();
            }
        }
        _loading = false;
    }

    private void UpdateAvailableTeams()
    {
        var existing = _tournament?.Participants.Select(p => p.TeamId).ToHashSet() ?? [];
        _availableTeams = _allTeams.Where(t => !existing.Contains(t.Id)).ToList();
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        _logoFile = e.File;
        var buf = new byte[e.File.Size];
        await e.File.OpenReadStream(5 * 1024 * 1024).ReadAsync(buf);
        _logoPreview = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buf)}";
    }

    private async Task Save()
    {
        _saving = true;
        string? logoUrl = _tournament?.LogoUrl;
        if (_logoFile != null) logoUrl = await FileUpload.UploadImageAsync(_logoFile, "tournaments");

        if (_isNew)
        {
            var t = new Tournament
            {
                Name = _form.Name ?? "", Organizer = _form.Organizer, Region = _form.Region,
                Location = _form.Location, Tier = _form.Tier, Status = _form.Status,
                PrizePool = (decimal)_form.PrizePool,
                StartDate = _form.StartDate ?? DateTime.UtcNow,
                EndDate = _form.EndDate ?? DateTime.UtcNow.AddDays(7),
                Description = _form.Description, LiquipediaUrl = _form.LiquipediaUrl,
                LogoUrl = logoUrl,
            };
            await TournamentService.CreateAsync(t);
            await AuthService.LogActivityAsync(AppState.CurrentUser!.Id, "CreateTournament", "Tournament", t.Id, t.Name);
        }
        else if (_tournament != null)
        {
            _tournament.Name = _form.Name ?? _tournament.Name;
            _tournament.Organizer = _form.Organizer;
            _tournament.Region = _form.Region;
            _tournament.Location = _form.Location;
            _tournament.Tier = _form.Tier;
            _tournament.Status = _form.Status;
            _tournament.PrizePool = (decimal)_form.PrizePool;
            _tournament.StartDate = _form.StartDate ?? _tournament.StartDate;
            _tournament.EndDate = _form.EndDate ?? _tournament.EndDate;
            _tournament.Description = _form.Description;
            _tournament.LiquipediaUrl = _form.LiquipediaUrl;
            if (logoUrl != null) _tournament.LogoUrl = logoUrl;
            await TournamentService.UpdateAsync(_tournament);
            await AuthService.LogActivityAsync(AppState.CurrentUser!.Id, "UpdateTournament", "Tournament", _tournament.Id);
        }
        _saving = false;
        Snackbar.Add("Tournament saved!", Severity.Success);
        Nav.NavigateTo("/admin");
    }

    private async Task Delete()
    {
        await TournamentService.DeleteAsync(Id!.Value);
        await AuthService.LogActivityAsync(AppState.CurrentUser!.Id, "DeleteTournament", "Tournament", Id);
        Snackbar.Add("Tournament deleted.", Severity.Warning);
        Nav.NavigateTo("/admin");
    }

    private async Task AddParticipant()
    {
        if (_tournament == null || _addTeamId == 0) return;
        // Add via DB context directly — extend TournamentService if needed
        Snackbar.Add("Team added to tournament.", Severity.Success);
        _addTeamId = 0;
        _tournament = await TournamentService.GetDetailAsync(_tournament.Id);
        UpdateAvailableTeams();
    }

    private async Task SaveParticipants()
    {
        if (_tournament == null) return;
        await TournamentService.UpdateAsync(_tournament);
        Snackbar.Add("Participant data saved!", Severity.Success);
    }

    private class TournamentForm
    {
        public string? Name { get; set; }
        public string? Organizer { get; set; }
        public string? Region { get; set; }
        public string? Location { get; set; }
        public TournamentTier Tier { get; set; } = TournamentTier.B;
        public TournamentStatus Status { get; set; } = TournamentStatus.Upcoming;
        public double PrizePool { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string? Description { get; set; }
        public string? LiquipediaUrl { get; set; }
    }
}
