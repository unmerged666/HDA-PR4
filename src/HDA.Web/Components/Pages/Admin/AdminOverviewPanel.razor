@using MudBlazor

<style>
.qa-btn {
    padding: 14px 16px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 700;
    font-family: var(--font-display);
    cursor: pointer;
    transition: all .2s cubic-bezier(.4,0,.2,1);
    text-align: left;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1.5px solid;
}
.qa-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.15);
    box-shadow: 0 6px 18px rgba(0,0,0,.25);
}
.qa-btn:active { transform: translateY(0); }

.qa-btn-gold   { color: var(--gold);   background: rgba(255,184,0,.08);   border-color: rgba(255,184,0,.3); }
.qa-btn-red    { color: var(--accent); background: rgba(232,64,87,.08);   border-color: rgba(232,64,87,.3); }
.qa-btn-purple { color: #A78BFA;       background: rgba(167,139,250,.08); border-color: rgba(167,139,250,.3); }
.qa-btn-green  { color: var(--green);  background: rgba(22,199,132,.08);  border-color: rgba(22,199,132,.3); }
.qa-btn-orange { color: #FB923C;       background: rgba(251,146,60,.08);  border-color: rgba(251,146,60,.3); }
.qa-btn-blue   { color: var(--blue);   background: rgba(75,158,255,.08);  border-color: rgba(75,158,255,.3); }

.stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: var(--bg3);
    border-radius: 8px;
    border: 1.5px solid var(--border);
    transition: border-color .18s, background .18s;
    cursor: default;
}
.stat-row:hover { background: var(--bg2); }
.stat-row-blue:hover   { border-color: rgba(75,158,255,.4); }
.stat-row-gold:hover   { border-color: rgba(255,184,0,.4); }
.stat-row-red:hover    { border-color: rgba(232,64,87,.4); }
.stat-row-purple:hover { border-color: rgba(167,139,250,.4); }
.stat-row-green:hover  { border-color: rgba(22,199,132,.4); }
.stat-row-orange:hover { border-color: rgba(251,146,60,.4); }
</style>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

    
    <div class="adm-card" style="padding:24px;">
        <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--t3);margin-bottom:18px;font-family:var(--font-display);">⚡ Быстрые действия</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <button class="qa-btn qa-btn-gold"   @onclick="@(()=>OnGo.InvokeAsync(2))"><span style="font-size:18px;">🏆</span> Добавить команду</button>
            <button class="qa-btn qa-btn-red"    @onclick="@(()=>OnGo.InvokeAsync(3))"><span style="font-size:18px;">⚔</span> Создать матч</button>
            <button class="qa-btn qa-btn-purple" @onclick="@(()=>OnGo.InvokeAsync(4))"><span style="font-size:18px;">🎯</span> Новый турнир</button>
            <button class="qa-btn qa-btn-green"  @onclick="@(()=>OnGo.InvokeAsync(5))"><span style="font-size:18px;">📰</span> Написать новость</button>
            <button class="qa-btn qa-btn-orange" @onclick="@(()=>OnGo.InvokeAsync(6))"><span style="font-size:18px;">🦸</span> Добавить игрока</button>
            <button class="qa-btn qa-btn-blue"   @onclick="@(()=>OnGo.InvokeAsync(7))"><span style="font-size:18px;">💻</span> Открыть консоль</button>
        </div>
    </div>

    
    <div class="adm-card" style="padding:24px;">
        <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--t3);margin-bottom:18px;font-family:var(--font-display);">📊 Статистика базы данных</div>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <div class="stat-row stat-row-blue">
                <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2);">👥 Пользователей</span>
                <span style="font-size:20px;font-weight:700;color:var(--blue);font-family:var(--font-mono);">@Stats.U</span>
            </div>
            <div class="stat-row stat-row-gold">
                <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2);">🏆 Команд</span>
                <span style="font-size:20px;font-weight:700;color:var(--gold);font-family:var(--font-mono);">@Stats.T</span>
            </div>
            <div class="stat-row stat-row-red">
                <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2);">⚔ Матчей</span>
                <span style="font-size:20px;font-weight:700;color:var(--accent);font-family:var(--font-mono);">@Stats.M</span>
            </div>
            <div class="stat-row stat-row-purple">
                <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2);">🎯 Турниров</span>
                <span style="font-size:20px;font-weight:700;color:#A78BFA;font-family:var(--font-mono);">@Stats.To</span>
            </div>
            <div class="stat-row stat-row-green">
                <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2);">📰 Новостей</span>
                <span style="font-size:20px;font-weight:700;color:var(--green);font-family:var(--font-mono);">@Stats.N</span>
            </div>
            <div class="stat-row stat-row-orange">
                <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2);">🦸 Про-игроков</span>
                <span style="font-size:20px;font-weight:700;color:#FB923C;font-family:var(--font-mono);">@Stats.P</span>
            </div>
        </div>
    </div>

</div>

@code {
    [Parameter] public S Stats { get; set; } = new();
    [Parameter] public EventCallback<int> OnGo { get; set; }
    public record S { public int U,T,M,To,N,P; }
}
